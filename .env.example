# Django secret key — generate your own, never commit the real value
SECRET_KEY=change-me-to-a-long-random-string

# Set to True only for local development
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Defaults to a local SQLite file if unset.
# For Postgres in production: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=sqlite:///db.sqlite3

# Reject uploads larger than this (bytes). Default: 10 MB.
FILEBRIDGE_MAX_UPLOAD_SIZE_BYTES=10485760
